/target
# Spike crates under spikes/ are standalone Cargo workspaces with
# their own target dirs (per ADR-0003 §Consequences).
spikes/*/target/
# Claude Code session-local state. The base `settings.json` and
# `hooks/` are shippable (project-wide permissions + pre-flight
# checks); everything else is per-user / runtime. Skills are local
# by default — opt project-process skills (e.g. /adr, /delegate,
# /sweep) into the repo with a targeted negation below. Note the
# `*` glob: gitignore can't re-include a file whose parent dir is
# excluded, so we ignore children of `.claude/skills/` instead of
# the directory itself.
.claude/settings.local.json
.claude/scheduled_tasks.lock
.claude/worktrees/
.claude/skills/*
!.claude/skills/adr/
!.claude/skills/approve/
!.claude/skills/audit/
!.claude/skills/bounce/
!.claude/skills/delegate/
!.claude/skills/implement/
!.claude/skills/orchestrate/
!.claude/skills/wish/
!.claude/skills/release-init/
!.claude/skills/scope/
!.claude/skills/scope-spinoff/
!.claude/skills/secretary/
!.claude/skills/sweep/
# Agent audit artifacts — runs of an audit workflow that examines
# the repo and emits findings. Outputs are per-run and per-machine,
# not part of the source tree; issues filed from them link back to
# the source instead.
/audits/
# Wish-pass reports — themed use-case ideation runs of `/wish`. Per-run
# markdown, not part of the source tree. Read locally, file the wishes you
# like as issues, discard the file.
/wishes/
# Trace dumps from `dump_trace` (issue #730 / ADR-0080). Per-run
# JSON, not part of the source tree — keep them out of /tmp so
# they survive shell sessions and land somewhere predictable. The
# directory itself is tracked via `.gitkeep` so the path is
# discoverable; everything else under it is ignored.
/traces/*
!/traces/.gitkeep
.claude/release-state.json
# Per-release unit dependency manifest consumed by /orchestrate. Like
# release-state.json: per-release operational state, regenerated per
# release, not source.
.claude/release-units.json
